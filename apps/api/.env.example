# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://etip:etip@localhost:5432/etip
DATABASE_URL_SYNC=postgresql+psycopg2://etip:etip@localhost:5432/etip  # Alembic

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=etip_skills

# ── Encryption (Fernet — connector secrets at rest) ───────
# Generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
CONNECTOR_ENCRYPTION_KEY=change-me-to-a-base64url-32-byte-key

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM (via LiteLLM — pick ONE provider) ─────────────────
# LLM_MODEL controls which provider/model is used. Examples:
#   gpt-4o-mini                    → OpenAI
#   claude-haiku-4-5-20251001      → Anthropic
#   groq/llama-3.3-70b-versatile   → Groq (free tier, recommended for dev)
#   ollama/llama3.2                → Local Ollama (fully free, no key)
LLM_MODEL=groq/llama-3.3-70b-versatile

# Only fill the key for the provider you chose above
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=gsk_...              # free at console.groq.com

# ── Embeddings (local OSS via fastembed — no API key needed) ─
# Model is downloaded once on first run (~130MB for bge-small)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── ESCO ──────────────────────────────────────────────────
ESCO_API_URL=https://ec.europa.eu/esco/api

# ── App ───────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
